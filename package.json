{
  "name": "atlas",
  "type": "module",
  "version": "0.1.0",
  "description": "An accessibility-first visual concept library",
  "author": "Serina Mcfall",
  "license": "ISC",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "run-p dev:client dev:server",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "run-s build:client build:server",
    "build:client": "vite build",
    "build:server": "esbuild --packages=external --platform=node --format=esm --outfile=dist/server.js --bundle server/index.ts",
    "test": "NODE_ENV=test vitest",
    "knex": "knex --knexfile=knexfile.ts",
    "migrate": "knex --knexfile=knexfile.ts migrate:latest",
    "rollback": "knex --knexfile=knexfile.ts migrate:rollback",
    "seed": "knex --knexfile=knexfile.ts seed:run",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier -w '**/*.{js,jsx,ts,tsx}'"
  },
  "eslintConfig": {
    "extends": [
      "@devacademy"
    ]
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "better-sqlite3": "^12.10.0",
    "express": "^4.22.1",
    "knex": "^3.2.10"
  },
  "devDependencies": {
    "@devacademy/eslint-config": "^1.10.2",
    "@tanstack/react-query": "^5.12.2",
    "@tanstack/react-query-devtools": "^5.13.3",
    "@testing-library/dom": "^8.17.1",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.17",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/superagent": "^8.1.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^22.1.0",
    "nock": "^14.0.5",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.13.0",
    "superagent": "^10.2.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
